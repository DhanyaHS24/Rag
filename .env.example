# Required: MinIO credentials (no defaults)
MINIO_ROOT_USER=admin_user
MINIO_ROOT_PASSWORD=replace_with_a_long_random_password
MINIO_BUCKET=raw-documents

# Required: JWT secret for authentication
JWT_SECRET=change_me_to_a_random_secret_key

# Optional: Embedding backend
EMBEDDING_BACKEND=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: Port overrides
FRONTEND_PORT=8502
UPLOAD_SERVICE_PORT=8004
RETRIEVAL_SERVICE_PORT=8005
USER_SERVICE_PORT=8003
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
NATS_PORT=4222
NATS_MONITOR_PORT=8222
CHROMA_PORT_HOST=8000
MONGO_PORT=27017
GARNET_PORT=6379
